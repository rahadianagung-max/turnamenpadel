{
  "version": 2,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/sheet.js" },
    { "source": "/score", "destination": "/score.html" },
    { "source": "/mobile/:slug", "destination": "/mobile.html" },
    { "source": "/tv/:slug", "destination": "/tv.html" },
    { "source": "/checkin/:slug", "destination": "/checkin.html" },
    { "source": "/contact", "destination": "/contact.html" }
  ]
}
